{
  "rewrites": [
    {
      "source": "/navidrome-api/:path*",
      "destination": "https://programmes-financing-brokers-continuity.trycloudflare.com/rest/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
